{
  "expo": {
    "name": "Jumix",
    "slug": "jumix",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "jumix",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "bundleIdentifier": "kz.jumix.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Нужен доступ к камере, чтобы сфотографировать удостоверение крановщика",
        "NSPhotoLibraryUsageDescription": "Нужен доступ к галерее, чтобы выбрать фото удостоверения крановщика"
      }
    },
    "android": {
      "package": "kz.jumix.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Нужен доступ к галерее, чтобы выбрать фото удостоверения крановщика",
          "cameraPermission": "Нужен доступ к камере, чтобы сфотографировать удостоверение крановщика"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
