{
  "name": "@jumix/api",
  "version": "0.0.0",
  "private": true,
  "description": "Jumix API — Fastify backend (REST + OpenAPI)",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.2",
    "@jumix/auth": "workspace:*",
    "@jumix/db": "workspace:*",
    "@jumix/shared": "workspace:*",
    "bullmq": "^5.76.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "minio": "^8.0.7",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jumix/config": "workspace:*",
    "@testcontainers/postgresql": "^10.14.0",
    "@types/node": "^22.9.0",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
