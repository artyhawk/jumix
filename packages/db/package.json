{
  "name": "@jumix/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema, миграции, seed, тип БД",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:reset": "drizzle-kit drop && pnpm db:generate && pnpm db:migrate && pnpm db:seed",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@jumix/config": "workspace:*",
    "@testcontainers/postgresql": "^10.14.0",
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "testcontainers": "^10.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
