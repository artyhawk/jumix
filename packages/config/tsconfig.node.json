{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Jumix Node.js (api / worker / packages)",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
