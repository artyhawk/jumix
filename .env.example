# ==============================================================================
# Jumix — переменные окружения (пример)
# Скопируйте в .env и заполните реальными значениями. .env в git НЕ коммитится.
# ==============================================================================

# --- App ---
NODE_ENV=development
TZ=Asia/Almaty
LOG_LEVEL=debug

# --- API ---
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000

# --- Database (dev docker-compose) ---
DATABASE_URL=postgresql://jumix:jumix_dev_pwd@localhost:5432/jumix

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO в dev; любой S3-совместимый backend в prod) ---
# Если STORAGE_ENDPOINT не задан, API падает на InMemoryStorageClient
# (подходит для тестов/локалки без docker-compose). В prod все поля обязательны
# — проверяется в server.ts (refine по NODE_ENV), как с REDIS_URL.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minio_admin
STORAGE_SECRET_KEY=minio_admin_dev_pwd
STORAGE_BUCKET=jumix-documents
STORAGE_FORCE_PATH_STYLE=true
# Presigned TTL (секунды). PUT короче — upload-сессия; GET длиннее — просмотр;
# PART — для multipart с мобилки на плохом интернете.
STORAGE_PRESIGN_GET_TTL_SECONDS=900
STORAGE_PRESIGN_PUT_TTL_SECONDS=300
STORAGE_PRESIGN_PART_TTL_SECONDS=900
# true в dev/test — плагин автосоздаёт бакет. В prod выставляем false,
# бакет провижинится инфрой (Terraform / ручной mc).
STORAGE_ENSURE_BUCKET=true

# --- Auth: JWT (RS256) ---
# Сгенерировать: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Хранить одной строкой с \n
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL_SEC=900          # 15 минут
JWT_REFRESH_TTL_WEB_SEC=2592000  # 30 дней
JWT_REFRESH_TTL_MOBILE_SEC=7776000 # 90 дней

# --- SMS (Mobizon) ---
MOBIZON_API_KEY=
MOBIZON_SENDER=JUMIX

# --- FCM (push-уведомления) ---
# Путь до service-account.json или inline (только для prod через secrets)
FCM_SERVICE_ACCOUNT_PATH=

# --- Rate limiting (per-IP defaults) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Mail (dev: MailHog) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@jumix.local

# --- Web (Next.js public) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_ENV=development
