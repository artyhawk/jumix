# ==============================================================================
# Jumix — production environment example (B3-UI-5b)
# Скопируйте в `.env.prod` на VPS и заполните РЕАЛЬНЫМИ значениями.
# .env.prod НИКОГДА не коммитится в git.
#
# Запуск:
#   docker compose -f infra/docker/docker-compose.prod.yml --env-file .env.prod up -d
# ==============================================================================

# --- Database (postgres service внутри compose) ---
POSTGRES_USER=jumix
# ОБЯЗАТЕЛЬНО replace: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=jumix

# --- Object storage (minio service) ---
# ОБЯЗАТЕЛЬНО replace: оба пароля >= 16 chars
MINIO_ROOT_USER=jumix_admin
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MINIO_BUCKET=jumix-prod
# Публичный URL для presigned download'ов (прозрачный для клиента).
# Если MinIO console exposed на субдомен — https://storage.jumix.kz
# Иначе используем /api/v1/storage proxy (backlog).
MINIO_PUBLIC_URL=https://storage.jumix.kz

# --- JWT (RS256 — сгенерировать одну пару, хранить одной строкой с \n) ---
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_SECRET=REPLACE_WITH_GENERATED_KEY_OR_PRIVATE_PEM
JWT_ISSUER=https://jumix.kz
JWT_AUDIENCE=jumix-app

# --- SMS gateway (Mobizon) ---
SMS_GATEWAY_URL=https://api.mobizon.kz
SMS_GATEWAY_KEY=REPLACE_WITH_MOBIZON_API_KEY

# --- Public URLs для web (Next.js client build) ---
# API обычно проксируется через /api на том же domain — оставить
# относительный '/api' если nginx reverse proxy на one domain.
PUBLIC_API_URL=/api
# Self-hosted pmtiles (B3-UI-5b). Пусто = fall-back на demo API.
# В prod скачать kz.pmtiles с https://maps.protomaps.com/builds + положить в
# /var/lib/jumix/tiles/kz.pmtiles. Затем URL: https://jumix.kz/tiles/kz.pmtiles
PUBLIC_TILES_URL=https://jumix.kz/tiles/kz.pmtiles

# --- Sentry (optional — empty → noop) ---
# Create project на sentry.io → copy DSN. Оставить пустым в dev/staging
# если не хотите слать ошибки.
SENTRY_DSN=
